# Database
DATABASE_URL="mysql://cimarket_user:cimarket_password@localhost:3306/cimarket_db"
DATABASE_HOST="localhost"
DATABASE_PORT="3306"
DATABASE_USER="cimarket_user"
DATABASE_PASSWORD="cimarket_password"
DATABASE_NAME="cimarket_db"

# Server hardening
PORT="8000"
# En producción usa solo orígenes HTTPS, por ejemplo:
# CORS_ORIGINS="https://cimarket.mx"
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://frontend:5173"
JSON_BODY_LIMIT="1mb"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="300"
AUTH_RATE_LIMIT_WINDOW_MS="900000"
AUTH_RATE_LIMIT_MAX="20"
TRUST_PROXY="false"

# Auth
# Clave secreta para firmar/verificar access tokens — mínimo 32 caracteres
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="dev-only-change-in-production-k8s7d9f2m4p6q1w3e5r7t9y0u2i4o6a8"
# Duración del access token (por defecto 20s para testing, usar 15m en producción). Los refresh tokens duran 7 días.
JWT_EXPIRATION="20s"
# Obtener en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="placeholder.apps.googleusercontent.com"

# Web Push / VAPID — generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:dev@cimarket.mx"
