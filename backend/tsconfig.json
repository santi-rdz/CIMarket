{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "./",
    "lib": ["esnext"],
    "rootDir": "..",
    "outDir": "dist",
    "declaration": true,
    "skipLibCheck": true,
    "paths": {
      "@cm/shared/*": ["../shared/*"],
      "#controllers/*": ["./src/controllers/*"],
      "#routes/*": ["./src/routes/*"],
      "#docs/*": ["./src/docs/*"],
      "#lib/*": ["./src/lib/*"],
      "#models/*": ["./src/models/*"],
      "#middlewares/*": ["./src/middlewares/*"],
      "#config/*": ["./config/*"],
      "#generated/*": ["./generated/*"],
      "#types/*": ["./src/types/*"]
    }
  },
  "include": ["src", "config", "generated", "../shared"],
  "exclude": ["node_modules", "dist"]
}
